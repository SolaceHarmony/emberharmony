# Copy into .env (do not commit .env)

# Model providers
ANTHROPIC_API_KEY=sk-ant-...

# GitHub (for local action simulation / tooling)
GITHUB_TOKEN=github_pat_...

# Web/console dev
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Desktop updater (optional)
# Public key (minisign public key, base64). Keep out of repo to avoid scanner false positives.
TAURI_UPDATER_PUBKEY=<base64-pubkey>

# Desktop updater signing (optional)
# Private key used to sign update artifacts. Must never be committed.
TAURI_SIGNING_PRIVATE_KEY=<minisign-private-key>
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=<password-if-any>

# Publishing (CI)
NPM_TOKEN=npm_<token>

