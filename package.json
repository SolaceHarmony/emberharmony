{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "emberharmony",
  "description": "EmberHarmony — the open source AI coding agent",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.8",
  "scripts": {
    "dev": "bun install && bun run --cwd packages/emberharmony --conditions=browser src/index.ts",
    "dev:stack": "bun install && bun run script/dev-stack.ts",
    "web": "bun install && bun run --cwd packages/emberharmony web",
    "serve": "bun install && bun run --cwd packages/emberharmony serve",
    "pack:local": "bun install && bun run --cwd packages/emberharmony pack:local",
    "install:local": "bun install && bun run --cwd packages/emberharmony install:local",
    "desktop:build": "bun run --cwd packages/desktop build:local",
    "desktop:build:nodmg": "bun run --cwd packages/desktop build:local:nodmg",
    "typecheck": "bun turbo typecheck",
    "prepare": "husky",
    "random": "echo 'Random script'",
    "hello": "echo 'Hello World!'",
    "probe:ollama": "bun run script/ollama-cloud-probe.ts",
    "test": "bun run script/test.ts"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "packages/console/*",
      "packages/sdk/js",
      "packages/slack",
      "github"
    ],
    "catalog": {
      "@types/bun": "1.3.8",
      "@octokit/rest": "22.0.0",
      "@hono/zod-validator": "0.4.2",
      "ulid": "3.0.1",
      "@kobalte/core": "0.13.11",
      "@types/luxon": "3.7.1",
      "@types/node": "22.13.9",
      "@types/semver": "7.7.1",
      "@tsconfig/node22": "22.0.2",
      "@tsconfig/bun": "1.0.9",
      "@cloudflare/workers-types": "4.20251008.0",
      "@openauthjs/openauth": "0.0.0-20250322224806",
      "@pierre/diffs": "1.0.2",
      "@solid-primitives/storage": "4.3.3",
      "@tailwindcss/vite": "4.1.11",
      "diff": "8.0.3",
      "dompurify": "3.3.3",
      "ai": "5.0.119",
      "hono": "4.12.12",
      "hono-openapi": "1.1.2",
      "fuzzysort": "3.1.0",
      "luxon": "3.6.1",
      "marked": "17.0.1",
      "marked-shiki": "1.2.1",
      "@playwright/test": "1.51.0",
      "typescript": "5.8.2",
      "@typescript/native-preview": "7.0.0-dev.20251207.1",
      "zod": "4.1.8",
      "remeda": "2.26.0",
      "shiki": "3.20.0",
      "solid-list": "0.3.0",
      "tailwindcss": "4.1.11",
      "virtua": "0.42.3",
      "vite": "7.3.2",
      "@solidjs/meta": "0.29.4",
      "@solidjs/router": "0.15.4",
      "@solidjs/start": "https://pkg.pr.new/@solidjs/start@dfb2020",
      "solid-js": "1.9.10",
      "vite-plugin-solid": "2.11.10"
    }
  },
  "devDependencies": {
    "@actions/artifact": "6.2.1",
    "@thesolaceproject/emberharmony-security-scanner": "workspace:*",
    "@tsconfig/bun": "catalog:",
    "husky": "9.1.7",
    "prettier": "3.6.2",
    "semver": "^7.6.0",
    "sst": "3.17.38",
    "turbo": "2.5.6"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.933.0",
    "@thesolaceproject/emberharmony-plugin": "workspace:*",
    "@thesolaceproject/emberharmony-script": "workspace:*",
    "@thesolaceproject/emberharmony-sdk": "workspace:*",
    "typescript": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SolaceHarmony/emberharmony"
  },
  "homepage": "https://solace.ofharmony.ai",
  "bugs": {
    "url": "https://github.com/SolaceHarmony/emberharmony/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Sydney Renee",
    "email": "sydney@solace.ofharmony.ai",
    "url": "https://solace.ofharmony.ai"
  },
  "prettier": {
    "semi": false,
    "printWidth": 120
  },
  "trustedDependencies": [
    "esbuild",
    "protobufjs",
    "tree-sitter",
    "tree-sitter-bash",
    "web-tree-sitter"
  ],
  "overrides": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@modelcontextprotocol/sdk": "1.26.0",
    "@remix-run/router": "1.23.2",
    "astro": "5.18.1",
    "diff": "8.0.3",
    "esbuild": "0.25.0",
    "file-type": "22.0.0",
    "h3": "1.15.11",
    "fast-xml-parser": "5.5.11",
    "hono": "4.12.12",
    "@isaacs/brace-expansion": "5.0.1",
    "react-router": "7.12.0",
    "seroval": "1.4.1",
    "undici": "7.22.0",
    "vite": "7.3.2",
    "wrangler": "4.59.1"
  },
  "patchedDependencies": {
    "ghostty-web@0.3.0": "patches/ghostty-web@0.3.0.patch"
  }
}
