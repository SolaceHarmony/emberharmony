#!/usr/bin/env node

const childProcess = require("child_process")
const fs = require("fs")
const path = require("path")
const os = require("os")

function run(target) {
  const result = childProcess.spawnSync(target, process.argv.slice(2), {
    stdio: "inherit",
  })
  if (result.error) {
    console.error(result.error.message)
    process.exit(1)
  }
  const code = typeof result.status === "number" ? result.status : 0
  process.exit(code)
}

const envPath = process.env.CODE_HARMONY_BIN_PATH
if (envPath) {
  run(envPath)
}

const scriptPath = fs.realpathSync(__filename)
const scriptDir = path.dirname(scriptPath)

function readPackageName() {
  try {
    const pkgPath = path.join(scriptDir, "..", "package.json")
    const pkg = JSON.parse(fs.readFileSync(pkgPath, "utf8"))
    const name = typeof pkg.name === "string" ? pkg.name : "code-harmony"
    return name.includes("/") ? name.split("/").pop() : name
  } catch {
    return "code-harmony"
  }
}

function readCpuInfo() {
  const path = "/proc/cpuinfo"
  if (!fs.existsSync(path)) return ""
  return fs.readFileSync(path, "utf8")
}

function hasAvx2() {
  const info = readCpuInfo()
  if (!info) return true
  return info.includes("avx2")
}

function isMusl(arch) {
  const checks = []
  if (arch === "x64") checks.push("/lib/ld-musl-x86_64.so.1")
  if (arch === "arm64") checks.push("/lib/ld-musl-aarch64.so.1")
  if (arch === "arm") checks.push("/lib/ld-musl-arm.so.1")
  checks.push("/lib/ld-musl.so.1")
  return checks.some((item) => fs.existsSync(item))
}

function localCandidates(platform, arch) {
  const list = []
  const base = platform + "-" + arch
  if (platform !== "linux") {
    list.push(base)
    list.push(base + "-baseline")
    return list
  }
  const musl = isMusl(arch)
  const baseline = arch === "x64" && !hasAvx2()
  const suffix = (baseline ? "-baseline" : "") + (musl ? "-musl" : "")
  list.push(base + suffix)
  if (musl) {
    list.push(base + (baseline ? "-baseline" : ""))
  }
  if (baseline) {
    if (musl) list.push(base + "-musl")
    list.push(base)
  }
  if (!baseline && !musl) {
    list.push(base + "-baseline")
  }
  return Array.from(new Set(list))
}

function findLocalBinary(startDir, platform, arch, binaryName) {
  const binDir = path.join(startDir, "bin")
  if (!fs.existsSync(binDir)) {
    return
  }
  const variants = localCandidates(platform, arch)
  for (const variant of variants) {
    const candidate = path.join(binDir, variant, binaryName)
    if (fs.existsSync(candidate)) {
      return candidate
    }
  }
}

const platformMap = {
  darwin: "darwin",
  linux: "linux",
  win32: "windows",
}
const archMap = {
  x64: "x64",
  arm64: "arm64",
  arm: "arm",
}

let platform = platformMap[os.platform()]
if (!platform) {
  platform = os.platform()
}
let arch = archMap[os.arch()]
if (!arch) {
  arch = os.arch()
}
const base = readPackageName() + "-" + platform + "-" + arch
const binary = platform === "windows" ? "code-harmony.exe" : "code-harmony"

function findBinary(startDir) {
  let current = startDir
  for (;;) {
    const modules = path.join(current, "node_modules")
    if (fs.existsSync(modules)) {
      const entries = fs.readdirSync(modules)
      for (const entry of entries) {
        if (!entry.startsWith(base)) {
          continue
        }
        const candidate = path.join(modules, entry, "bin", binary)
        if (fs.existsSync(candidate)) {
          return candidate
        }
      }
    }
    const parent = path.dirname(current)
    if (parent === current) {
      return
    }
    current = parent
  }
}

const local = findLocalBinary(scriptDir, platform, arch, binary)
if (local) {
  run(local)
}

const resolved = findBinary(scriptDir)
if (!resolved) {
  console.error(
    'It seems that your package manager failed to install the right version of the code-harmony CLI for your platform. You can try manually installing the "' +
      base +
      '" package',
  )
  process.exit(1)
}

run(resolved)
