{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeHarmony",
  "identifier": "ai.ofharmony.code",
  "bundle": {
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/prod/32x32.png",
      "icons/prod/128x128.png",
      "icons/prod/128x128@2x.png",
      "icons/prod/icon.icns",
      "icons/prod/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/prod/icon.ico"
      }
    },
    "linux": {
      "deb": {
        "files": {
          "/usr/share/metainfo/ai.ofharmony.code.metainfo.xml": "release/appstream.metainfo.xml"
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "__SET_TAURI_UPDATER_PUBKEY_AT_BUILD_TIME__",
      "endpoints": ["https://github.com/SolaceHarmony/code-harmony/releases/latest/download/latest.json"]
    }
  }
}
