{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ],
      "cache": false
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ],
      "cache": false
    },
    "emberharmony#test": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [],
      "cache": false
    },
    "@thesolaceproject/emberharmony-app#test": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [],
      "cache": false
    }
  }
}
